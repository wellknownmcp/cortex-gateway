{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wellknownmcp/cortex-gateway",
  "description": "Federated MCP gateway: one OAuth 2.1-protected MCP server in front of N plain-HTTP backends, with scope-filtered tools, live discovery and audit trail.",
  "repository": {
    "url": "https://github.com/wellknownmcp/cortex-gateway",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "oci",
      "registryBaseUrl": "https://ghcr.io",
      "identifier": "ghcr.io/wellknownmcp/cortex-gateway:0.1.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:3213/mcp"
      },
      "environmentVariables": [
        { "name": "CORTEX_CANONICAL_URI", "description": "Canonical MCP resource URI (RFC 9728)", "isRequired": true, "isSecret": false, "format": "string" },
        { "name": "OAUTH_ISSUER", "description": "OAuth 2.1 authorization server URL", "isRequired": true, "isSecret": false, "format": "string" },
        { "name": "CORTEX_BACKENDS", "description": "Comma-separated federated backend ids", "isRequired": true, "isSecret": false, "format": "string" },
        { "name": "CORTEX_TECHNICAL_TOKEN", "description": "Static token for backend catalog discovery", "isRequired": true, "isSecret": true, "format": "string" }
      ]
    }
  ]
}
