// cortex-demo-auth — Prisma schema
//
// Demo OAuth 2.1 authorization server. Users self-register through magic
// links; the 5 OAuth models follow the validated authorization-server
// blueprint (hybrid stateless+revocable access tokens, strict refresh
// rotation with theft detection, PKCE-bound single-use codes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

// ─── Users + magic-link login ───────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")
  // Scopes granted to this user's tokens at consent time. Demo tiering:
  // everyone gets DEFAULT_USER_SCOPES at signup; flip entries here to
  // demonstrate scope-based tool visibility (free vs pro).
  scopes      String[]  @default(["mcp:demo:read"])

  sessions      Session[]
  magicLinks    MagicLink[]
  authCodes     OauthAuthorizationCode[]
  accessTokens  OauthAccessToken[]
  refreshTokens OauthRefreshToken[]
  consents      OauthConsentGrant[]

  @@map("users")
}

model MagicLink {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at") // 15 min
  usedAt    DateTime? @map("used_at")

  @@index([expiresAt])
  @@map("magic_links")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") // 7 days

  @@index([expiresAt])
  @@map("sessions")
}

// ─── OAuth 2.1 authorization server ─────────────────────────────────────────

// OAuth client registered via DCR (RFC 7591).
model OauthClient {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId         String  @unique @map("client_id") @db.VarChar(100)
  clientSecretHash String? @map("client_secret_hash") @db.VarChar(200) // null = public client (PKCE-only)
  clientName       String  @map("client_name") @db.VarChar(200)
  clientUri        String? @map("client_uri") @db.VarChar(500)
  logoUri          String? @map("logo_uri") @db.VarChar(500)

  clientType              String   @default("public") @map("client_type") @db.VarChar(20)
  redirectUris            String[] @map("redirect_uris")
  grantTypes              String[] @default(["authorization_code", "refresh_token"]) @map("grant_types")
  responseTypes           String[] @default(["code"]) @map("response_types")
  scopesAllowed           String[] @default([]) @map("scopes_allowed")
  tokenEndpointAuthMethod String   @default("none") @map("token_endpoint_auth_method") @db.VarChar(50)

  registeredBy    String? @map("registered_by") @db.VarChar(255)
  softwareId      String? @map("software_id") @db.VarChar(100)
  softwareVersion String? @map("software_version") @db.VarChar(50)

  disabled         Boolean   @default(false)
  disabledReason   String?   @map("disabled_reason") @db.VarChar(500)
  moderationStatus String    @default("approved") @map("moderation_status") @db.VarChar(20)
  lastUsedAt       DateTime? @map("last_used_at")

  authCodes     OauthAuthorizationCode[]
  accessTokens  OauthAccessToken[]
  refreshTokens OauthRefreshToken[]
  consents      OauthConsentGrant[]

  @@index([clientId])
  @@index([disabled])
  @@map("oauth_clients")
}

// Authorization code (10 min, single-use, PKCE-bound)
model OauthAuthorizationCode {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  codeHash String @unique @map("code_hash") @db.VarChar(64)

  clientId String      @map("client_id") @db.Uuid
  client   OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id") @db.Uuid
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  redirectUri         String   @map("redirect_uri") @db.Text
  scopes              String[]
  codeChallenge       String   @map("code_challenge") @db.VarChar(200)
  codeChallengeMethod String   @default("S256") @map("code_challenge_method") @db.VarChar(10)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  @@index([codeHash])
  @@index([expiresAt])
  @@map("oauth_authorization_codes")
}

// Access token (JWT signed stateless + hash in DB for revocation, 15 min)
model OauthAccessToken {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tokenHash String @unique @map("token_hash") @db.VarChar(64)

  clientId String      @map("client_id") @db.Uuid
  client   OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id") @db.Uuid
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes    String[]
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  // Truncated (/24) at write time — never store full IPs (data minimization)
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId])
  @@map("oauth_access_tokens")
}

// Refresh token (opaque 256 bits, rotated on every use, 30d rolling)
model OauthRefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tokenHash String @unique @map("token_hash") @db.VarChar(64)

  clientId String      @map("client_id") @db.Uuid
  client   OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id") @db.Uuid
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes      String[]
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  rotatedToId String?   @map("rotated_to_id") @db.Uuid

  @@index([tokenHash])
  @@index([userId, clientId])
  @@map("oauth_refresh_tokens")
}

// Persistent consent grant (30d) — skips the consent screen on re-auth
model OauthConsentGrant {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId   String      @map("user_id") @db.Uuid
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String      @map("client_id") @db.Uuid
  client   OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  scopes    String[]
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  @@unique([userId, clientId])
  @@map("oauth_consent_grants")
}
