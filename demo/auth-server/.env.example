# ── Identity ────────────────────────────────────────────────────────────────
# Public URL of THIS authorization server (behind your reverse proxy).
OAUTH_ISSUER=https://auth.cortex-gateway.dev
# Audience of issued access tokens = the gateway's canonical MCP URI.
OAUTH_MCP_AUDIENCE=https://mcp.cortex-gateway.dev/mcp

# ── Signing keys (bash scripts/generate-oauth-keys.sh >> .env) ──────────────
OAUTH_KEY_ID=
OAUTH_SIGNING_PRIVATE_KEY=
OAUTH_SIGNING_PUBLIC_KEY=

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://user:pass@localhost:5432/cortex_demo_auth

# ── Magic-link email (Resend). Without a key, links are printed to stdout —
#    fine locally, NOT for a public deployment. ─────────────────────────────
#RESEND_API_KEY=
#AUTH_EMAIL_FROM=Cortex Demo <auth@cortex-gateway.dev>

# ── Introspection client (RFC 7662) — the gateway's service credential.
#    Mirror these values in the gateway's OAUTH_INTROSPECT_CLIENT_ID/SECRET. ─
INTROSPECT_CLIENT_ID=cortex-gateway
INTROSPECT_CLIENT_SECRET=change-me
