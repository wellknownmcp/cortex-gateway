# ── Identity of this gateway ────────────────────────────────────────────────
# Canonical URI of the MCP resource (RFC 9728). Used as the default JWT
# audience and in the WWW-Authenticate discovery header.
CORTEX_CANONICAL_URI=https://mcp.example.com/mcp
# Display name in `initialize` serverInfo and on the status page.
CORTEX_SERVER_NAME=cortex-gateway

# ── OAuth 2.1 (resource server) ─────────────────────────────────────────────
# Your authorization server. JWKS is fetched at <issuer>/.well-known/jwks.json
# unless OAUTH_JWKS_URL overrides it.
OAUTH_ISSUER=https://auth.example.com
# Audience expected on tokens. Defaults to CORTEX_CANONICAL_URI.
#OAUTH_AUDIENCE=https://mcp.example.com/mcp
#OAUTH_JWKS_URL=

# Optional RFC 7662 introspection (revocation detection, 60s cache)
#OAUTH_INTROSPECT_URL=https://auth.example.com/oauth/introspect
#OAUTH_INTROSPECT_CLIENT_ID=
#OAUTH_INTROSPECT_CLIENT_SECRET=
#OAUTH_INTROSPECT_CACHE_TTL_SECONDS=60

# Optional: only accept tokens carrying this `pool` claim (population sandbox)
#CORTEX_REQUIRED_POOL=admin

# ── Federated backends ──────────────────────────────────────────────────────
# Comma-separated backend ids, then one URL per id. A backend without a URL
# is silently skipped.
CORTEX_BACKENDS=demo
CORTEX_BACKEND_DEMO_URL=http://127.0.0.1:4820
#CORTEX_BACKEND_DEMO_PATH=/api/cortex/backend
#CORTEX_BACKEND_DEMO_TIMEOUT_MS=10000

# Static technical token used ONLY for catalog discovery
# (list_tools / list_prompts / list_resource_templates / get_snapshot).
# Each backend must accept it for those methods and refuse it for data methods.
CORTEX_TECHNICAL_TOKEN=change-me

# Backends that own their missing-capability tickets (implement
# report_missing_capability + list_tickets natively)
#CORTEX_TICKET_BACKENDS=demo

# ── Security / limits ───────────────────────────────────────────────────────
# Allowed web origins (exact origins or *.suffix wildcards). Local MCP clients
# send no Origin header and are always accepted.
CORTEX_ALLOWED_ORIGINS=https://claude.ai,*.anthropic.com
CORTEX_RATE_LIMIT_PER_MINUTE=200

# ── Optional persistence (PostgreSQL) ───────────────────────────────────────
# Without it the gateway still runs: audit stays on stdout, gateway-local
# tickets are disabled.
#CORTEX_DATABASE_URL=postgresql://user:pass@localhost:5432/cortex_gateway
#CORTEX_AUDIT_RETENTION_DAYS=365
# Secret protecting /api/cron/purge-audit
#CRON_SECRET=

# ── Notifications ───────────────────────────────────────────────────────────
# Webhook receiving blocking missing-capability tickets (plain JSON POST)
#CORTEX_TICKET_WEBHOOK_URL=

# ── Local development ───────────────────────────────────────────────────────
# OAuth bypass for local testing (non-production + localhost only):
# send the header `X-Dev-Mode: <token>` instead of a Bearer JWT.
#CORTEX_DEV_BYPASS_TOKEN=dev-secret
#CORTEX_DEV_BYPASS_SCOPES=mcp:demo:read,mcp:demo:write
#CORTEX_DEV_BYPASS_ROLE=admin
