# ── Identity of this gateway ────────────────────────────────────────────────
# Canonical URI of the MCP resource (RFC 9728). Used as the default JWT
# audience and in the WWW-Authenticate discovery header.
CORTEX_CANONICAL_URI=https://mcp.example.com/mcp
# Display name in `initialize` serverInfo and on the status page.
CORTEX_SERVER_NAME=cortex-gateway

# ── OAuth 2.1 (resource server) ─────────────────────────────────────────────
# Your authorization server. JWKS is fetched at <issuer>/.well-known/jwks.json
# unless OAUTH_JWKS_URL overrides it.
OAUTH_ISSUER=https://auth.example.com
# Audience expected on tokens. Defaults to CORTEX_CANONICAL_URI.
#OAUTH_AUDIENCE=https://mcp.example.com/mcp
#OAUTH_JWKS_URL=

# Optional RFC 7662 introspection (revocation detection, 60s cache)
#OAUTH_INTROSPECT_URL=https://auth.example.com/oauth/introspect
#OAUTH_INTROSPECT_CLIENT_ID=
#OAUTH_INTROSPECT_CLIENT_SECRET=
#OAUTH_INTROSPECT_CACHE_TTL_SECONDS=60

# Optional: only accept tokens carrying this `pool` claim (population sandbox)
#CORTEX_REQUIRED_POOL=admin

# Optional baseline scope, required before any dispatch. Per-tool scopes are
# the authorization model; the gateway builtins (whoami, list_cortex_resources,
# ...) require none by design — so without a floor, any valid token for this
# audience reaches them. See docs/security.md §5.
#OAUTH_REQUIRED_SCOPES=mcp:access

# ── Federated backends ──────────────────────────────────────────────────────
# Comma-separated backend ids, then one URL per id. A backend without a URL
# is silently skipped.
CORTEX_BACKENDS=demo
CORTEX_BACKEND_DEMO_URL=http://127.0.0.1:4820
#CORTEX_BACKEND_DEMO_PATH=/api/cortex/backend
#CORTEX_BACKEND_DEMO_TIMEOUT_MS=10000

# Static technical token used ONLY for catalog discovery
# (list_tools / list_prompts / list_resource_templates / get_snapshot).
# Each backend must accept it for those methods and refuse it for data methods.
CORTEX_TECHNICAL_TOKEN=change-me

# Backends that own their missing-capability tickets (implement
# report_missing_capability + list_tickets natively)
#CORTEX_TICKET_BACKENDS=demo

# ── Security / limits ───────────────────────────────────────────────────────
# Allowed web origins (exact origins or *.suffix wildcards), checked BEFORE
# OAuth to prevent DNS rebinding. Local MCP clients send no Origin header and
# are always accepted — which is why a connector can work in Claude Desktop and
# fail on a web client with the same server.
#
# Every web-based MCP client you want to support must be listed here. An origin
# that is absent gets 403 on the CORS preflight: the real request is never sent,
# no OAuth challenge is ever produced, and the connector fails SILENTLY.
# See https://cortex-gateway.dev/answers/mcp-connector-does-nothing/ (cause 3).
CORTEX_ALLOWED_ORIGINS=https://claude.ai,*.anthropic.com
CORTEX_RATE_LIMIT_PER_MINUTE=200

# Tool definition integrity — rug-pull detection (docs/security.md §1).
# A backend that rewrites a tool's description or inputSchema while keeping its
# name changes what the model is told, under an approval that still looks valid.
#   warn  (default) log the mutation + push tools/list_changed, serve the new one
#   block           quarantine the tool until an operator reviews it
#CORTEX_TOOL_INTEGRITY_MODE=warn

# Outbound transport policy (docs/security.md §2). The caller's bearer token is
# forwarded to every backend, so plaintext HTTP to a REMOTE host is refused and
# the backend is dropped at load. Loopback stays allowed (stdio bridge, local
# dev). Set this only when transport is secured at another layer (service mesh,
# WireGuard) — never for production over the open internet.
#CORTEX_ALLOW_INSECURE_BACKENDS=true

# ── MCP→backend proxy adapter (federate native MCP servers) ────────────────
# See docs/mcp-adapter.md. Requires CORTEX_DATABASE_URL (token vault).
#CORTEX_MCP_SERVERS=canva,figma
#CORTEX_MCP_CANVA_URL=https://mcp.canva.com/mcp
#CORTEX_MCP_CANVA_SCOPE=mcp:canva:read
#CORTEX_MCP_CANVA_CLIENT_ID=            # optional — DCR when absent
#CORTEX_MCP_CANVA_CLIENT_SECRET=
#CORTEX_MCP_CANVA_OAUTH_SCOPE=
#CORTEX_MCP_CANVA_CATALOG_SUB=          # linked sub used for tools/list discovery
# ... then federate each one as a loopback backend:
#CORTEX_BACKEND_CANVA_URL=http://127.0.0.1:3213
#CORTEX_BACKEND_CANVA_PATH=/api/mcp-adapter/canva/backend

# Vault key protecting downstream OAuth tokens at rest (openssl rand -base64 32)
#CORTEX_VAULT_KEY=

# ── Optional persistence (PostgreSQL) ───────────────────────────────────────
# Without it the gateway still runs: audit stays on stdout, gateway-local
# tickets are disabled.
#CORTEX_DATABASE_URL=postgresql://user:pass@localhost:5432/cortex_gateway
#CORTEX_AUDIT_RETENTION_DAYS=365
# Secret protecting /api/cron/purge-audit
#CRON_SECRET=

# ── Notifications ───────────────────────────────────────────────────────────
# Webhook receiving blocking missing-capability tickets (plain JSON POST)
#CORTEX_TICKET_WEBHOOK_URL=

# ── Local development ───────────────────────────────────────────────────────
# OAuth bypass for local testing (non-production + localhost only):
# send the header `X-Dev-Mode: <token>` instead of a Bearer JWT.
#CORTEX_DEV_BYPASS_TOKEN=dev-secret
#CORTEX_DEV_BYPASS_SCOPES=mcp:demo:read,mcp:demo:write
#CORTEX_DEV_BYPASS_ROLE=admin
